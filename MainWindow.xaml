<Window x:Class="ExpenseTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Expense Tracker" Height="500" Width="850">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NASLOV + add dugme -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Naslov -->
            <TextBlock Text="Expense Tracker"
               FontSize="26"
               FontWeight="Bold"
               VerticalAlignment="Center"/>

            <!-- Add dugme -->
            <Button Grid.Column="1"
            Content="+"
            Width="35"
            Height="35"
            FontSize="18"
            FontWeight="Bold"
            Background="#2E7D32"
            Foreground="White"
            BorderThickness="0"
            Cursor="Hand"
            Click="Add_Click"/>
        </Grid>
        <!--  SEARCH + TOTAL -->
        <Grid Grid.Row="1" Margin="0,0,0,10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- Search -->
                <ColumnDefinition Width="*"/>
                <!-- prazno - gura Total desno -->
                <ColumnDefinition Width="Auto"/>
                <!-- Total -->
            </Grid.ColumnDefinitions>

           

            <!-- SEARCH -->
            <StackPanel Grid.Column="0"
            Orientation="Horizontal"
            VerticalAlignment="Center">

                <TextBlock Text="Search"
               VerticalAlignment="Center"
               Margin="0,0,8,0"/>

                <TextBox x:Name="SearchBox"
             Width="180"
             Height="30"
             VerticalAlignment="Center"
             TextChanged="Search_TextChanged"/>

            </StackPanel>

            <!-- TOTAL -->
            <TextBlock x:Name="txtTotal"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       FontSize="16"
                       FontWeight="Bold"/>
        </Grid>

        <!-- TABELA -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Expenses}"
                  FontSize="13"
                  AutoGenerateColumns="False"
                  RowHeight="30"
                  BorderThickness="0"
                  GridLinesVisibility="None"
                  AlternatingRowBackground="#F7F7F7"
                  Background="White"
                  CanUserAddRows="False"
                  HeadersVisibility="Column">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#2E7D32"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Height" Value="35"/>
                    <!-- povećana visina headera -->
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="BorderBrush" Value="Gray"/>
                    <Setter Property="BorderThickness" Value="0,0,2,2"/>
                    <Setter Property="Padding" Value="5"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>


                <DataGridTextColumn Header="Description"
                    Binding="{Binding Description}"
                    Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="Margin" Value="5,0,0,0"/>
                            <!-- malo prostora sa leve strane -->
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Amount"
                        Binding="{Binding Amount}"
                        Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Margin" Value="0,0,5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Date"
                        Binding="{Binding ExpenseDate, StringFormat=d}"
                        Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Margin" Value="5,0,0,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Paid (CheckBox): centrirano -->
                <DataGridTemplateColumn Header="Paid" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsPaid}"
                          Checked="PaidChanged"
                          Unchecked="PaidChanged"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Edit + Delete: centrirano -->
                <DataGridTemplateColumn Header="Actions" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="Edit_Click">
                                    <Image Source="/Icons/edit-icon.png"
                                       Width="18"
                                       Height="18"/>
                                </Button>

                                <Button Width="35"
                                    Height="30"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="Delete_Click">
                                    <Image Source="/Icons/delete-icon.png"
                                       Width="18"
                                       Height="18"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Window>