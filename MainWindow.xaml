<Window x:Class="ExpenseTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExpenseTracker"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.Resources>

        <Style x:Key="RightAlign" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

    </Window.Resources>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Dugme -->
        <Button Content="Add Expense"
            Width="120"
            Height="40"
            Click="Add_Click"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"/>

        <!-- Lista rashoda -->
        <DataGrid Grid.Row="1"
          ItemsSource="{Binding Expenses}"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          Margin="0,10,0,0"
          RowHeight="35"
          BorderThickness="0"
          GridLinesVisibility="None"
          AlternatingRowBackground="#F7F7F7"
          Background="White"
          CanUserAddRows="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Description"
                            Binding="{Binding Description}"
                            Width="*"/>

                <DataGridTextColumn Header="Amount"
                            Binding="{Binding Amount}"
                            Width="120"/>

                <DataGridTextColumn Header="Date"
                            Binding="{Binding ExpenseDate, StringFormat=d}"
                            Width="150"/>

                <DataGridCheckBoxColumn Header="Paid"
                                Binding="{Binding IsPaid}"
                                Width="80"/>

                <!-- Dugmad -->
                <DataGridTemplateColumn Header="" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                               
                                <Button Width="35"
                                    Height="30"
                                    Background="Transparent"
                                    BorderThickness="0"
    
                                    Cursor="Hand">

                                    <Image Source="/Icons/editicon.png"
                                   Width="20"
                                   Height="20"/>
                                </Button>
                                <Button Width="35"
                                    Height="30"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="Delete_Click"
                                    CommandParameter="{Binding}">
                                    <!-- {Binding} znači da se prosleđuje trenutni Expense iz reda DataGrid-a. -->
                                   
                                    <Image Source="/Icons/delete-icon.png"
                                       Width="20"
                                       Height="20"/>
                                </Button>
                                
                            </StackPanel>

                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</Window>
