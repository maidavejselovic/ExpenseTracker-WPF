<Window x:Class="ExpenseTracker.Windows.AddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ExpenseTracker.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Add Expense"
        Height="410"
        Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="20">
        <StackPanel>
            <!-- Title -->
            <TextBlock Text="Add New Expense"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

            <!-- Description -->
            <TextBlock Text="Description" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     Height="30"
                     FontSize="13"
                     Padding="2"
                     Margin="0,5,0,15"
                     BorderBrush="#BDBDBD"
                     BorderThickness="1"
                     Background="White"/>

            <!-- Amount -->
            <TextBlock Text="Amount" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                     Height="30"
                     FontSize="13"
                     Padding="2"
                     Margin="0,5,0,15"
                     BorderBrush="#BDBDBD"
                     BorderThickness="1"
                     Background="White"/>

            <!-- Date -->
            <TextBlock Text="Date" FontWeight="SemiBold"/>
            <DatePicker SelectedDate="{Binding ExpenseDate, UpdateSourceTrigger=PropertyChanged}"
                        Height="30"
                        FontSize="13"
                        Margin="0,5,0,15"
                        DisplayDateStart="2020-01-01"
                        DisplayDateEnd="{x:Static sys:DateTime.Now}"/>

            <!-- Is Paid -->
            <CheckBox Content="Paid"
                      IsChecked="{Binding IsPaid}"
                      FontSize="13"
                      Margin="0,5,0,20"/>

            <!-- Save Button -->
            <Button Content="Save"
                 Width="120"
                 Height="35"
                 HorizontalAlignment="Center"
                 FontSize="15"
                 FontWeight="Bold"
                 Background="#2E7D32"
                 BorderBrush="#1B5E20"
                 BorderThickness="1"
                 Cursor="Hand"
                 Command="{Binding SaveCommand}"
                 CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                 Padding="3">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <!-- Default Foreground (boja kada je dugme enabled) -->
                        <Setter Property="Foreground" Value="White"/>
                        <!-- Trigger za stanje Disabled -->
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="Gray"/>
                                <Setter Property="Background" Value="#1B5E20"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>