<Window x:Class="ExpenseTracker.Windows.AddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Expense" Height="350" Width="300">
    <Grid Margin="10">
        <StackPanel>
            <!-- Description -->
            <TextBlock Text="Description"/>
            <TextBox x:Name="txtDescription" Margin="0,5" TextChanged="InputChanged"/>
            <TextBlock x:Name="txtDescriptionError" Foreground="Red" FontSize="12" Visibility="Collapsed" Text="Description is required"/>

            <!-- Amount -->
            <TextBlock Text="Amount"/>
            <TextBox x:Name="txtAmount" Margin="0,5" TextChanged="InputChanged"/>
            <TextBlock x:Name="txtAmountError" Foreground="Red" FontSize="12" Visibility="Collapsed" Text="Amount is required"/>

            <!-- Date -->
            <TextBlock Text="Date"/>
            <DatePicker x:Name="dpDate" Margin="0,5"/>
            <TextBlock x:Name="dpDateError" Foreground="Red" FontSize="12" Visibility="Collapsed" Text="Date is required"/>


            <!-- IsPaid -->
            <CheckBox x:Name="chkPaid" Content="Is Paid" Margin="0,5"/>

            <!-- Save button -->
            <Button x:Name="btnSave" Content="Save" Width="80" Margin="0,10,0,0" HorizontalAlignment="Left"
                    Click="Save_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>