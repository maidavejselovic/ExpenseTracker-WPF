<Window x:Class="ExpenseTracker.Windows.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Expense"
        Height="350"
        Width="300">

    <Grid Margin="10">
        <StackPanel>

            <TextBlock Text="Description"/>
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

            <TextBlock Text="Amount"/>
            <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

            <TextBlock Text="Date"/>
            <DatePicker SelectedDate="{Binding ExpenseDate, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

            <CheckBox Content="Is Paid"
                      IsChecked="{Binding IsPaid}"
                      Margin="0,5"/>

            <Button Content="Save"
                    Width="80"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Left"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

        </StackPanel>
    </Grid>
</Window>