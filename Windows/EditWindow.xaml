<Window x:Class="ExpenseTracker.Windows.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExpenseTracker.Windows"
        mc:Ignorable="d"
        Title="EditWindow" Height="400" Width="400">
    <Grid Margin="10">

        <StackPanel>

            <TextBlock Text="Description"/>
            <TextBox x:Name="txtDescription" Margin="0,5"/>

            <TextBlock Text="Amount"/>
            <TextBox x:Name="txtAmount" Margin="0,5"/>

            <TextBlock Text="Date"/>
            <DatePicker x:Name="dpDate" Margin="0,5"/>

            <CheckBox x:Name="chkPaid" Content="Is Paid" Margin="0,5"/>

            <Button Content="Save"
                    Width="80"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Left"
                    Click="Save_Click"/>

        </StackPanel>

    </Grid>
</Window>
